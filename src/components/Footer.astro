---
/**
 * Footer — My Site
 * Espresso background, three-column layout, gold rule separators.
 */
---

<footer class="bg-espresso relative">
  <!-- Top gold rule -->
  <hr class="gold-rule" />

  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-8 md:py-10">
    <!-- Five-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 md:gap-8 lg:gap-10">

      <!-- Column 1 — Services -->
      <nav aria-label="Footer navigation">
        <h3 class="text-cream font-body font-semibold text-sm tracking-wide uppercase mb-4">
          Services
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/services/paid-media"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Paid Media
            </a>
          </li>
          <li>
            <a
              href="/services/ai-performance-creative"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              AI Performance Creative
            </a>
          </li>
          <li>
            <a
              href="/services/conversion-optimization"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Conversion Optimization
            </a>
          </li>
          <li>
            <a
              href="/services#lifecycle"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Lifecycle & Retention
            </a>
          </li>
          <li>
            <a
              href="/services#growth-strategy"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Growth Strategy & Leadership
            </a>
          </li>
          <li>
            <a
              href="/services#aeo-geo"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              AEO / GEO Optimization
            </a>
          </li>
        </ul>
      </nav>

      <!-- Column 2 — Who It's For -->
      <nav aria-label="Audiences we serve">
        <h3 class="text-cream font-body font-semibold text-sm tracking-wide uppercase mb-4">
          Who It's For
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/for/plg-saas"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              PLG SaaS
            </a>
          </li>
          <li>
            <a
              href="/for/ai-companies"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              AI Companies
            </a>
          </li>
          <li>
            <a
              href="/for/subscription"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Subscription
            </a>
          </li>
          <li>
            <a
              href="/for/consumer"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Consumer
            </a>
          </li>
        </ul>
      </nav>

      <!-- Column 3 — Resources -->
      <div>
        <h3 class="text-cream font-body font-semibold text-sm tracking-wide uppercase mb-4">
          Resources
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/about"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/case-studies"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Case Studies
            </a>
          </li>
          <li>
            <a
              href="/blog"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Blog
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4 — Contact -->
      <div>
        <h3 class="text-cream font-body font-semibold text-sm tracking-wide uppercase mb-4">
          Contact
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/contact"
              class="text-muted-stone text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 hover:translate-x-0.5 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 active:translate-x-0 inline-block"
            >
              Book a Free Strategy Call
            </a>
          </li>
          <li>
            <a
              href="mailto:hello@example.com"
              class="text-teal text-sm font-body transition-opacity transition-transform duration-150 ease-out-expo hover:opacity-80 hover:translate-x-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal active:opacity-60 active:translate-x-0 inline-block"
            >
              hello@example.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 5 — Brand -->
      <div>
        <a href="/" aria-label="My Site — Home" class="inline-block mb-4 transition-opacity duration-150 ease-out-expo hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold active:opacity-60">
          <img
            src="/logos/logo-dark.svg"
            alt="My Site"
            class="h-7 w-auto"
            loading="lazy"
          />
        </a>
        <p class="text-muted-stone font-body text-sm leading-relaxed mb-3">
          Growth marketing for SaaS, PLG, and AI companies.
        </p>
        <p class="text-muted-stone font-body text-sm leading-relaxed opacity-80">
          Powered by the Acceleration Framework — a unified system that aligns paid media, creative, conversion, and lifecycle into a single growth engine.
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <hr class="gold-rule mt-12 mb-6" />

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-muted-stone text-xs font-body">
        &copy; 2026 My Site. All rights reserved.
      </p>
      <a
        href="/privacy-policy"
        class="text-muted-stone text-xs font-body transition-opacity transition-transform duration-150 ease-out-expo hover:text-cream hover:opacity-90 focus-visible:text-cream focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:opacity-70 inline-block"
      >
        Privacy Policy
      </a>
    </div>
  </div>
</footer>
