---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';
import { gitLastModified } from '../../lib/gitLastModified.js';

const caseStudies = await getCollection('case-studies');
const creativeStudies = caseStudies.filter(s => ['zencastr', 'benlabs'].includes(s.id));

const testimonials = await getCollection('testimonials');
const mattTestimonial = testimonials.find(t => t.id === 'matt-plotnik');

// Selected Work gallery removed pending new English creative assets.
// To restore: re-add the works array, the Selected Work <ScrollReveal> section,
// and the .work-video styles in the <style> block at the bottom of this file.
---

<BaseLayout title="AI Performance Creative — My Site" description="AI performance creative production using GPT Image 2, Nano Banana Pro, Seedance 2.0, and Kling 3.0. 500+ variants tested monthly. Recent client TikTok campaign dropped CPA 50%.">

  <!-- Service JSON-LD -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI Performance Creative",
    "provider": {
      "@type": "Organization",
      "name": "My Site",
      "url": "https://example.com"
    },
    "description": "AI performance creative production using GPT Image 2, Nano Banana Pro, Seedance 2.0, and Kling 3.0. 500+ variants tested monthly, with a recent TikTok campaign that dropped CPA 50% versus the same campaign run earlier with paid creators.",
    "url": "https://example.com/services/ai-performance-creative",
    "dateModified": gitLastModified('src/pages/services/ai-performance-creative.astro', "2026-05-02")
  })} />

  <!-- HowTo JSON-LD -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How My Site Produces AI Performance Creative",
    "description": "A three-step workflow: human creative direction, AI image and video generation, then ship and measure in market.",
    "step": [
      {
        "@type": "HowToStep",
        "position": 1,
        "name": "Creative direction",
        "text": "Our creative director works alongside a Claude Code creative agent to develop angles, hooks, and the specific human moments each variant will capture. The brief defines who, where, and what emotional beat the avatar plays."
      },
      {
        "@type": "HowToStep",
        "position": 2,
        "name": "Image and video generation",
        "text": "Photorealistic stills are generated in GPT Image 2 or Nano Banana Pro through the Codex CLI. Stills are then animated in Seedance 2.0 or Kling 3.0, batched through Lovart so 20 variants render unattended."
      },
      {
        "@type": "HowToStep",
        "position": 3,
        "name": "Ship, go to market, measure",
        "text": "Variants ship into paid social, performance data feeds back into the next round, and winning hooks scale while losers retire the same day. The most recent client TikTok campaign run on this workflow dropped CPA 50% versus the same campaign's previous creator-shot ads."
      }
    ]
  })} />

  <!-- FAQPage JSON-LD -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is AI performance creative?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AI performance creative is the discipline of producing high-volume ad creative using generative AI tools (image, video, copy) under human creative direction, then testing variants against performance metrics like CPA, ROAS, and CTR. My Site runs this workflow with GPT Image 2 and Nano Banana Pro for stills, Seedance 2.0 and Kling 3.0 for animation, and a Claude Code creative director agent for briefing."
        }
      },
      {
        "@type": "Question",
        "name": "What results has AI performance creative produced?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "On the most recent client TikTok campaign run on this workflow, CPA dropped roughly 50% versus the previous version of the campaign that used paid creators. Production speed increased about 10x, with 12 to 20 variants per sprint instead of the 2 to 4 a creator shoot typically delivers."
        }
      },
      {
        "@type": "Question",
        "name": "Is AI-generated creative just AI slop?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, and the gallery on this page is the answer. The avatars are photorealistic, the lighting is intentional, and the briefs are written by a human creative director before a single image is generated. Generic AI output happens when nobody owns the point of view. Strong AI performance creative happens when a human still directs the brief and the model executes the production."
        }
      },
      {
        "@type": "Question",
        "name": "How many creative variants does My Site produce?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "12 to 20 finished variants per sprint, 500+ tested monthly across client portfolios. Traditional creator-shot pipelines typically deliver 2 to 4 per sprint."
        }
      }
    ]
  })} />

  <!-- Back nav -->
  <div class="max-w-5xl mx-auto px-6 lg:px-8 pt-8">
    <a href="/services" class="inline-flex items-center text-sm text-muted-stone hover:text-gold transition-colors duration-150">
      <span class="mr-1">←</span> All Services
    </a>
  </div>

  <!-- Hero -->
  <section class="py-12 md:py-20 warm-glow-strong">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <span class="section-number mb-4 block">AI Performance Creative</span>
      <h1 class="font-headline text-3xl md:text-5xl tracking-tightest text-cream headline-glow">
        AI Performance Creative
      </h1>
      <p class="text-muted-stone mt-6 text-lg leading-relaxed max-w-3xl">
        Turn creative from a production bottleneck into a testing system.
      </p>
      <p class="text-muted-stone mt-4 text-lg leading-relaxed max-w-3xl">
        We produce, launch, and learn from more creative variants in less time, so your team can find winning hooks faster and lower acquisition costs without waiting weeks for each new round of assets.
      </p>
    </div>
  </section>

  <!-- Stat Bar -->
  <div class="border-y border-dark-umber py-8">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4 text-center md:text-left">
        <div>
          <p class="metric-value text-3xl md:text-4xl" data-count-to="50" data-suffix="%">50%</p>
          <p class="metric-label mt-1">lower CPA on our last client campaign</p>
        </div>
        <div>
          <p class="metric-value text-3xl md:text-4xl" data-count-to="500" data-suffix="+">500+</p>
          <p class="metric-label mt-1">variants tested monthly</p>
        </div>
        <div>
          <p class="metric-value text-3xl md:text-4xl" data-count-to="10" data-suffix="x">10x</p>
          <p class="metric-label mt-1">production speed</p>
        </div>
        <div>
          <p class="metric-value text-3xl md:text-4xl" data-count-to="20" data-suffix="+">20+</p>
          <p class="metric-label mt-1">variants per sprint</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Selected Work Gallery removed pending new English creative assets. -->
  <!-- See the workflow case study for current sample work: /blog/ai-performance-creative-workflow -->

  <!-- Supporting Copy -->
  <ScrollReveal>
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl text-cream">Most teams do not have a creative quality problem. They have a creative velocity problem.</h2>
      <div class="mt-6 space-y-4">
        <p class="text-muted-stone text-base leading-relaxed">The market moves faster than traditional production cycles. Winning ads need more hooks, more angles, more formats, and faster feedback loops.</p>
        <p class="text-muted-stone text-base leading-relaxed">We help teams build a creative testing system that moves quickly without turning the brand into a mess.</p>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- How We Build -->
  <ScrollReveal>
  <section class="py-12 md:py-16 bg-warm-slate border-y border-dark-umber">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl text-cream">How We Build AI Performance Creative</h2>
      <div class="mt-10 space-y-10">
        <div class="border-l-2 border-gold/30 pl-6">
          <span class="font-mono text-sm text-gold tracking-wider">Step 1</span>
          <h3 class="font-headline text-xl text-cream mt-1">Creative direction</h3>
          <p class="text-muted-stone text-base leading-relaxed mt-3">
            Our human creative director works alongside a Claude Code creative agent to develop angles, hooks, and the specific human moments each variant will capture. The brief defines who, where, and what emotional beat the avatar plays. This is the step that stops the rest of the pipeline from making generic AI output.
          </p>
        </div>
        <div class="border-l-2 border-gold/30 pl-6">
          <span class="font-mono text-sm text-gold tracking-wider">Step 2</span>
          <h3 class="font-headline text-xl text-cream mt-1">Image and video generation</h3>
          <p class="text-muted-stone text-base leading-relaxed mt-3">
            Photorealistic stills are generated in GPT Image 2 or Nano Banana Pro, scripted through the Codex CLI so we can batch 4 to 12 variants of the same character at once. Stills then move into Seedance 2.0 or Kling 3.0 for animation, with Lovart queuing the renders so 20 videos finish unattended.
          </p>
        </div>
        <div class="border-l-2 border-gold/30 pl-6">
          <span class="font-mono text-sm text-gold tracking-wider">Step 3</span>
          <h3 class="font-headline text-xl text-cream mt-1">Ship, go to market, measure</h3>
          <p class="text-muted-stone text-base leading-relaxed mt-3">
            Variants ship into the live ad account, performance data feeds back into the next round, and winners scale while losers get killed the same day. On our last campaign run this way, CPA dropped 50%.
          </p>
        </div>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Comparison Table -->
  <ScrollReveal>
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl text-cream">AI Performance Creative vs. The Old Way</h2>
      <p class="text-muted-stone mt-3 text-base leading-relaxed max-w-2xl">
        Three production paths, three very different speeds and ceilings.
      </p>
      <div class="mt-8 comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>What you compare</th>
              <th>Hiring Creators</th>
              <th>Traditional Agency</th>
              <th>AI Performance Creative</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Time per variant</td>
              <td>5 to 10 days</td>
              <td>2 to 4 weeks</td>
              <td>Under 1 hour of human time</td>
            </tr>
            <tr>
              <td>Variants per sprint</td>
              <td>2 to 4</td>
              <td>4 to 8</td>
              <td>12 to 20</td>
            </tr>
            <tr>
              <td>Casting flexibility</td>
              <td>Whoever fits the budget</td>
              <td>Whoever the agency can book</td>
              <td>Any character you can describe</td>
            </tr>
            <tr>
              <td>Time to swap losers for winners</td>
              <td>Weeks</td>
              <td>Weeks</td>
              <td>Same day</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Tool Stack -->
  <section class="bg-warm-slate border-y border-dark-umber py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl text-cream">The Tools Change. The System Matters More.</h2>
      <div class="mt-6 space-y-4">
        <p class="text-muted-stone text-base leading-relaxed">
          We use modern AI tools to move faster, but the point is not the tool stack. The point is better testing.
        </p>
        <p class="text-muted-stone text-base leading-relaxed">
          The goal is to produce more useful creative, learn faster, and scale the messages that actually move customers.
        </p>
      </div>
    </div>
  </section>

  <!-- Read the Playbook -->
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="rounded-brand-md border border-dark-umber bg-warm-slate/40 p-8 md:p-10">
        <span class="font-mono text-xs text-gold tracking-wider uppercase">The Playbook</span>
        <h2 class="font-headline text-2xl md:text-3xl text-cream mt-4">Want the full picture before talking to us?</h2>
        <p class="text-muted-stone text-base leading-relaxed mt-4">
          We wrote the entire 2026 playbook (workflow, economics, tool stack, the first 30 days of standing this up inside a growth team) so you can read before you decide. It is the same approach we run on client accounts.
        </p>
        <a href="/blog/ai-performance-creative-playbook" class="inline-flex items-center gap-2 mt-6 text-gold hover:text-amber transition-colors duration-150">
          <span class="font-body text-base">Read the AI Performance Creative Playbook</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Results -->
  <ScrollReveal>
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl text-cream mb-8">Results</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {creativeStudies.map((study) => (
          <CaseStudyCard
            title={study.data.title}
            client={study.data.client}
            challenge={study.data.challenge}
            heroMetric={study.data.heroMetric}
            heroMetricLabel={study.data.heroMetricLabel}
            service={study.data.service}
            slug={study.id}
            featuredImage={study.data.featuredImage}
            secondaryMetric={study.data.secondaryMetric}
            secondaryMetricLabel={study.data.secondaryMetricLabel}
          />
        ))}
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Testimonial -->
  {mattTestimonial && (
    <section class="py-12 md:py-16 border-t border-dark-umber">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
        <blockquote class="font-headline text-xl md:text-2xl text-cream/90 leading-relaxed italic">
          "{mattTestimonial.data.quote}"
        </blockquote>
        <div class="mt-6">
          <p class="text-cream font-body text-sm font-semibold">{mattTestimonial.data.name}</p>
          <p class="text-muted-stone text-sm">{mattTestimonial.data.title}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="py-16 md:py-24 text-center warm-glow-strong">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-3xl md:text-4xl text-cream headline-glow">Ready to ship AI performance creative for your account?</h2>
      <p class="text-muted-stone mt-4 text-lg">Book a free strategy call. We will walk you through the workflow and show you what it would look like for your product.</p>
      <a href="/contact" class="btn-cta mt-8 inline-block">Book a Free Strategy Call →</a>
      <p class="text-muted-stone/60 text-sm mt-4">Typically responds within 24 hours</p>
    </div>
  </section>

  <!-- Last Updated -->
  <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-8 text-right">
    <span class="font-mono text-xs text-muted-stone/60">Last updated: May 2026</span>
  </div>

</BaseLayout>

<style>
  .comparison-table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    -webkit-overflow-scrolling: touch;
  }
  .comparison-table {
    width: 100%;
    min-width: 640px;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.9375rem;
  }
  .comparison-table thead {
    background: rgba(201, 169, 110, 0.06);
  }
  .comparison-table th {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-accent-gold);
    text-align: left;
    padding: 0.875rem 1.125rem;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    vertical-align: top;
  }
  .comparison-table td {
    color: var(--color-text-secondary);
    padding: 1rem 1.125rem;
    vertical-align: top;
    line-height: 1.6;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }
  .comparison-table tbody tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.015);
  }
  .comparison-table tbody td:first-child {
    color: var(--color-text-primary);
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .comparison-table td,
    .comparison-table th {
      padding: 0.75rem 0.875rem;
    }
    .comparison-table {
      font-size: 0.875rem;
    }
  }
</style>
